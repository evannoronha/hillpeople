{
  "collectionName": "components_shared_video_embeds",
  "info": {
    "displayName": "Video Embed",
    "description": "Embedded video (YouTube iframe, HTML5 video, etc.)"
  },
  "attributes": {
    "url": {
      "type": "string",
      "required": true
    },
    "title": {
      "type": "string"
    },
    "provider": {
      "type": "enumeration",
      "enum": ["youtube", "vimeo", "html5", "other"],
      "default": "other"
    },
    "rawHtml": {
      "type": "text"
    }
  }
}
